{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/efitz/Projects/tmi-ux && pnpm run format 2>/dev/null; exit 0",
            "statusMessage": "Auto-formatting..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -qE '\\.(env|lock)$|pnpm-lock'; then echo 'BLOCKED: Cannot edit env/lock files'; exit 1; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./scripts/:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(done)",
      "Bash(echo:*)",
      "Bash(env)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(heroku:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(ng:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pgrep:*)",
      "Bash(pip3:*)",
      "Bash(pkill:*)",
      "Bash(pnpm:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(sed:*)",
      "Bash(tree:*)",
      "Bash(true)",
      "Bash(uv:*)",
      "Read(//tmp/**)",
      "WebFetch(domain:angular.dev)",
      "WebFetch(domain:devblogs.microsoft.com)",
      "WebFetch(domain:x6.antv.vision)",
      "WebFetchTool(domain:angular.io)",
      "WebFetchTool(domain:github.com)",
      "WebSearch",
      "Skill(translate_to_language)",
      "Skill(translate_to_language:*)",
      "WebFetch(domain:vitest.dev)"
    ]
  }
}
